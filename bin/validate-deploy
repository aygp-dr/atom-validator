#!/usr/bin/env bash
# validate-deploy - Audit JAR for secrets before Clojars deployment
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
AUDIT_DIR="${TMPDIR:-/tmp}/jar-audit-$$"

cd "$PROJECT_DIR"

echo "=== Building JAR ==="
clojure -T:build jar

JAR_FILE=$(ls -1 target/*.jar 2>/dev/null | head -1)
if [[ -z "$JAR_FILE" ]]; then
    echo "ERROR: No JAR file found in target/"
    exit 1
fi

echo ""
echo "=== Auditing: $JAR_FILE ==="
mkdir -p "$AUDIT_DIR"
unzip -q "$JAR_FILE" -d "$AUDIT_DIR"

ISSUES=0

# Check for secrets patterns
echo "Checking for secrets..."
if grep -rEi "(password|secret|api.?key|credential|private.?key|access.?token)" "$AUDIT_DIR" 2>/dev/null | grep -v "\.clj:.*:keys\|pom\.xml.*Connection"; then
    echo "WARNING: Potential secret patterns found"
    ISSUES=$((ISSUES + 1))
fi

# Check for hardcoded tokens (CLOJARS_, ghp_, sk-, etc.)
echo "Checking for hardcoded tokens..."
if grep -rE "(CLOJARS_[a-f0-9]{20,}|ghp_[A-Za-z0-9]{36}|sk-[A-Za-z0-9]{48}|AIza[A-Za-z0-9_-]{35})" "$AUDIT_DIR" 2>/dev/null; then
    echo "ERROR: Hardcoded token found!"
    ISSUES=$((ISSUES + 1))
fi

# Check for email addresses (excluding git URLs)
echo "Checking for email addresses..."
if grep -rEi "[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\.(com|org|net|io)" "$AUDIT_DIR" 2>/dev/null | grep -v "git@github\|scm:git"; then
    echo "WARNING: Email address found"
    ISSUES=$((ISSUES + 1))
fi

# Check for .env files or similar
echo "Checking for config files..."
if find "$AUDIT_DIR" -name ".env*" -o -name "*.pem" -o -name "*.key" 2>/dev/null | grep -q .; then
    echo "ERROR: Sensitive config file found!"
    ISSUES=$((ISSUES + 1))
fi

# Check for large encoded strings (potential embedded secrets)
echo "Checking for encoded strings..."
if grep -rE "[A-Za-z0-9+/]{100,}={0,2}" "$AUDIT_DIR" 2>/dev/null; then
    echo "WARNING: Large base64-like string found"
    ISSUES=$((ISSUES + 1))
fi

# Cleanup
rm -rf "$AUDIT_DIR"

echo ""
if [[ $ISSUES -eq 0 ]]; then
    echo "=== AUDIT PASSED ==="
    echo "JAR is clean: $JAR_FILE"
    echo ""

    if [[ "${1:-}" == "--deploy" ]]; then
        echo "=== Deploying to Clojars ==="
        make deploy
    else
        echo "Run with --deploy to publish, or:"
        echo "  make deploy"
    fi
    exit 0
else
    echo "=== AUDIT FAILED: $ISSUES issue(s) found ==="
    exit 1
fi
